# ==== Django ====
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Em produção (Railway): DJANGO_DEBUG=False. O domínio do Railway é liberado
# automaticamente via RAILWAY_PUBLIC_DOMAIN. Para domínio próprio, liste aqui:
# DJANGO_ALLOWED_HOSTS=meurestaurante.com.br
# DJANGO_CSRF_TRUSTED_ORIGINS=https://meurestaurante.com.br

# No Railway, o banco vem pronto nesta variável (não precisa preencher Postgres abaixo):
# DATABASE_URL=postgresql://...

# ==== Banco de Dados ====
# True (padrão atual): SQLite local, ideal para demonstração.
# False: usa o PostgreSQL configurado abaixo (produção).
DJANGO_USE_SQLITE=True

# ==== PostgreSQL (usado quando DJANGO_USE_SQLITE=False) ====
POSTGRES_DB=restaurante
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ==== Agente de impressão (comanda na cozinha) ====
# Token compartilhado entre o servidor e o agente que roda no PC do restaurante.
# Gere um valor aleatório longo. No PC, rode o print_agent.py com:
#   PRINT_API_URL=https://seu-app.up.railway.app  PRINT_API_TOKEN=<o mesmo valor>
IMPRESSAO_API_TOKEN=

# ==== Modo de simulação (testes sem credenciais reais) ====
# True: Pix fake + WhatsApp só no log. Mude para False quando tiver as credenciais.
MODO_SIMULACAO=True

# ==== Meta Cloud API (WhatsApp) — usado na Fase 3 ====
META_VERIFY_TOKEN=token-de-verificacao-do-webhook
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_API_VERSION=v21.0
# Flow publicado na Meta para multi-select de acompanhamentos (importar bot/flows/acompanhamentos.flow.json)
META_PIX_NATIVO=False
# True = order_details com pix_dynamic_code (requer Payments API BR + chave_pix na loja)
META_FLOW_ACOMPANHAMENTOS_ID=

# ==== Asaas (Pix) — usado na Fase 2 ====
ASAAS_API_KEY=
# Sandbox: https://sandbox.asaas.com/api/v3  |  Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token configurado no painel do Asaas para autenticar o webhook (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=
# CPF/CNPJ padrão para criar cliente no Asaas (sandbox aceita CPF de teste)
ASAAS_DEFAULT_CPF_CNPJ=
